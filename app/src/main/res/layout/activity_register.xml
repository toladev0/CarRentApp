<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        tools:ignore="MissingConstraints">

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scaleType="fitEnd"
            android:src="@drawable/background"
            tools:ignore="ContentDescription,ImageContrastCheck" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="100dp"
                android:fontFamily="@font/inter_bold"
                android:text="@string/create_account"
                android:textAlignment="center"
                android:textColor="@color/colorPrimary"
                android:textSize="34sp"
                android:textStyle="bold"
                tools:ignore="TextContrastCheck" />

            <TextView
                android:layout_width="300dp"
                android:layout_height="100dp"
                android:fontFamily="@font/inter_medium"
                android:text="@string/creating_an_account_so_you_can_explore_all_existing_car"
                android:textAlignment="center"
                android:textColor="@color/black"
                android:textSize="22sp"
                tools:ignore="TextSizeCheck" />

            <EditText
                android:id="@+id/editTextEmailAddress"
                android:layout_width="340dp"
                android:layout_height="wrap_content"
                android:layout_marginBottom="30dp"
                android:autofillHints="emailAddress"
                android:background="@drawable/edittext_bg"
                android:fontFamily="@font/inter"
                android:hint="@string/email"
                android:text="admin@example.com"
                android:inputType="textEmailAddress"
                android:padding="12dp"
                tools:ignore="TextContrastCheck" />

            <EditText
                android:id="@+id/editTextPassword"
                android:layout_width="340dp"
                android:layout_height="wrap_content"
                android:layout_marginBottom="30dp"
                android:autofillHints=""
                android:background="@drawable/edittext_bg"
                android:fontFamily="@font/inter"
                android:hint="@string/password"
                android:text="admin123"
                android:inputType="textPassword"
                android:padding="12sp"
                tools:ignore="TextContrastCheck" />

            <EditText
                android:id="@+id/editTextConfirmPassword"
                android:layout_width="340dp"
                android:layout_height="wrap_content"
                android:autofillHints=""
                android:background="@drawable/edittext_bg"
                android:fontFamily="@font/inter"
                android:hint="@string/confirm_password"
                android:text="admin123"
                android:inputType="textPassword"
                android:padding="12sp"
                tools:ignore="TextContrastCheck" />

            <Button
                android:id="@+id/signUpButton"
                android:layout_width="340dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="50dp"
                android:backgroundTint="@color/colorPrimary"
                android:text="@string/sign_up"
                android:textColor="@color/white"
                android:textSize="16sp"
                app:cornerRadius="10dp"
                tools:ignore="TextContrastCheck,VisualLintButtonSize" />

            <TextView
                android:id="@+id/alreadyHaveAccountLink"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginVertical="20dp"
                android:text="@string/already_have_account"
                android:textAlignment="center"
                android:textColor="@color/black"
                android:textSize="16sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/or_continue_with"
                android:textAlignment="center"
                android:textColor="@color/colorPrimary"
                android:textSize="16sp"
                tools:ignore="TextContrastCheck" />

            <LinearLayout
                android:layout_width="300dp"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="20dp"
                android:gravity="center" >

                <ImageView
                    android:id="@+id/googleRegisterIcon"
                    android:layout_width="0dp"
                    android:layout_height="60dp"
                    android:layout_weight="1"
                    android:src="@drawable/google_logo"
                    tools:ignore="ContentDescription" />

                <ImageView
                    android:id="@+id/facebookRegisterIcon"
                    android:layout_width="0dp"
                    android:layout_height="64dp"
                    android:layout_weight="1"
                    android:src="@drawable/facebook_logo"
                    tools:ignore="ContentDescription" />

                <ImageView
                    android:id="@+id/appleIdRegisterIcon"
                    android:layout_width="0dp"
                    android:layout_height="64dp"
                    android:layout_weight="1"
                    android:src="@drawable/apple_logo"
                    tools:ignore="ContentDescription" />

            </LinearLayout>

        </LinearLayout>

    </RelativeLayout>

</androidx.constraintlayout.widget.ConstraintLayout>